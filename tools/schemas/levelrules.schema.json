{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/JKLeckr/schemas/refs/heads/apworld-v01/levelrules.schema.json",
  "$comment": "Copyright 2025-2026 JKLeckr, SPDX-License-Identifier: BSD-2-Clause",
  "schema_version": "v1",
  "title": "APWorld Level Rules",
  "description": "Schema for defining level rules in an Archipelago APWorld.",
  "type": "object",
  "required": ["levels"],
  "properties": {
    "$comment": { "$ref": "#/$defs/comment" },
    "levels": {
      "type": "object",
      "propertyNames": { "type": "string" },
      "additionalProperties": { "$ref": "#/$defs/level" }
    }
  },
  "additionalProperties": false,

  "$defs": {
    "refString": {
      "type": "string",
      "pattern": "^!?[A-Za-z_][A-Za-z0-9_]*$"
    },

    "ruleDep": { "$ref": "#/$defs/refString" },

    "whenList": {
      "type": "array",
      "items": { "$ref": "#/$defs/ruleDep" },
      "uniqueItems": true
    },

    "ruleExpr": {
      "oneOf": [
        {
          "type": "object",
          "required": ["rule"],
          "properties": {
            "rule": { "$ref": "#/$defs/refString" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["preset"],
          "properties": {
            "preset": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["and"],
          "properties": {
            "and": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/ruleExpr" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["or"],
          "properties": {
            "or": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/ruleExpr" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["not"],
          "properties": {
            "not": { "$ref": "#/$defs/ruleExpr" }
          },
          "additionalProperties": false
        }
      ]
    },

    "ruleFragment": {
      "type": "object",
      "required": ["requires"],
      "properties": {
        "$comment": { "$ref": "#/$defs/comment" },
        "when": { "$ref": "#/$defs/whenList" },
        "requires": { "$ref": "#/$defs/ruleExpr" }
      },
      "additionalProperties": false
    },

    "ruleList": {
      "type": "array",
      "items": { "$ref": "#/$defs/ruleFragment" }
    },

    "ruleContainer": {
      "type": "object",
      "properties": {
        "$comment": { "$ref": "#/$defs/comment" },
        "rules": { "$ref": "#/$defs/ruleList" }
      },
      "additionalProperties": false
    },

    "location": {
      "type": "object",
      "properties": {
        "$comment": { "$ref": "#/$defs/comment" },
        "rule": { "$ref": "#/$defs/ruleContainer" },
        "inherit": {
          "type": "string",
          "enum": ["and", "or", "none"]
        }
      },
      "additionalProperties": false
    },

    "level": {
      "type": "object",
      "properties": {
        "$comment": { "$ref": "#/$defs/comment" },
        "access": { "$ref": "#/$defs/ruleContainer" },
        "base": { "$ref": "#/$defs/ruleContainer" },
        "locations": {
          "type": "object",
          "propertyNames": { "type": "string" },
          "additionalProperties": { "$ref": "#/$defs/location" }
        }
      },
      "additionalProperties": false
    },

    "comment": {
      "type": "string",
      "description": "Optional human-readable comment"
    }
  }
}
