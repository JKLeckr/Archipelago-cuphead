{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/JKLeckr/schemas/refs/heads/apworld-v01/levelrules.schema.json",
  "$comment": "Copyright 2025-2026 JKLeckr, SPDX-License-Identifier: BSD-2-Clause",
  "schema_version": "v1",
  "title": "APWorld Level Rules",
  "description": "Schema for defining level rules in an Archipelago APWorld.",
  "type": "object",
  "required": ["levels"],
  "properties": {
    "$comment": { "$ref": "#/$defs/comment" },
    "levels": {
      "type": "object",
      "propertyNames": { "type": "string" },
      "additionalProperties": { "$ref": "#/$defs/level" }
    }
  },
  "additionalProperties": false,

  "$defs": {
    "ruleDepRef": {
      "type": "string"
    },

    "whenList": {
      "type": "array",
      "items": { "$ref": "#/$defs/ruleDepRef" },
      "uniqueItems": true
    },

    "apItemRef": {
      "type": "string"
    },

    "apItemGroupRef": {
      "type": "string"
    },

    "apItemSelectorRef": {
      "type": "string"
    },

    "ruleDefs": {
      "type": "object",
      "propertyNames": { "type": "string" },
      "additionalProperties": { "$ref": "#/$defs/ruleContainer" }
    },

    "fromExpr": {
      "type": "object",
      "required": ["from"],
      "properties": {
        "from": { "type": "string" }
      },
      "additionalProperties": false
    },

    "ruleItemExpr": {
      "oneOf": [
        {
          "type": "object",
          "required": ["has"],
          "properties": {
            "has": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/apItemRef" }
            },
            "has_any": { "type": "boolean" },
            "count": { "type": "integer" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["has_selection"],
          "properties": {
            "has_selection": { "$ref": "#/$defs/apItemSelectorRef" },
            "has_any": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["has_from_list"],
          "properties": {
            "has_from_list": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/apItemRef" }
            },
            "count": { "type": "integer" },
            "unique": { "type": "boolean" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["has_group"],
          "properties": {
            "has_group": { "$ref": "#/$defs/apItemGroupRef" },
            "count": { "type": "integer" },
            "unique": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },

    "ruleExpr": {
      "oneOf": [
        {
          "type": "object",
          "required": ["preset"],
          "properties": {
            "preset": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["rule"],
          "properties": {
            "rule": { "$ref": "#/$defs/ruleItemExpr" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["and"],
          "properties": {
            "and": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/ruleExpr" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["or"],
          "properties": {
            "or": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/ruleExpr" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["not"],
          "properties": {
            "not": { "$ref": "#/$defs/ruleExpr" }
          },
          "additionalProperties": false
        }
      ]
    },

    "ruleFragment": {
      "type": "object",
      "required": ["requires"],
      "properties": {
        "$comment": { "$ref": "#/$defs/comment" },
        "when": { "$ref": "#/$defs/whenList" },
        "requires": {
          "oneOf": [{ "type": "boolean" }, { "$ref": "#/$defs/ruleExpr" }]
        }
      },
      "additionalProperties": false
    },

    "ruleList": {
      "type": "array",
      "items": { "$ref": "#/$defs/ruleFragment" }
    },

    "ruleContainer": {
      "type": "object",
      "properties": {
        "$comment": { "$ref": "#/$defs/comment" },
        "rules": { "$ref": "#/$defs/ruleList" }
      },
      "additionalProperties": false
    },

    "location": {
      "type": "object",
      "properties": {
        "$comment": { "$ref": "#/$defs/comment" },
        "rules": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/ruleFragment" },
              { "$ref": "#/$defs/fromExpr" }
            ]
          }
        },
        "inherit": {
          "type": "string",
          "enum": ["and", "or", "none"]
        }
      },
      "additionalProperties": false
    },

    "level": {
      "type": "object",
      "properties": {
        "$comment": { "$ref": "#/$defs/comment" },
        "access": { "$ref": "#/$defs/ruleContainer" },
        "base": { "$ref": "#/$defs/ruleContainer" },
        "rule_defs": { "$ref": "#/$defs/ruleDefs" },
        "locations": {
          "type": "object",
          "propertyNames": { "type": "string" },
          "additionalProperties": { "$ref": "#/$defs/location" }
        }
      },
      "additionalProperties": false
    },

    "comment": {
      "type": "string",
      "description": "Optional human-readable comment"
    }
  }
}
