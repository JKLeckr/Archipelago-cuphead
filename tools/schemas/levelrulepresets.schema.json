{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/JKLeckr/schemas/refs/heads/apworld-v01/levelrulepresets.schema.json",
  "$comment": "Copyright 2025-2026 JKLeckr, SPDX-License-Identifier: BSD-2-Clause",
  "type": "object",
  "required": ["presets"],

  "properties": {
    "$comment": { "$ref": "levelrules.schema.json#/$defs/comment" },
    "presets": {
      "type": "object",
      "propertyNames": { "type": "string" },
      "additionalProperties": { "$ref": "#/$defs/preset" }
    }
  },
  "additionalProperties": false,

  "$defs": {
    "preset": {
      "type": "object",
      "required": ["rules"],
      "properties": {
        "$comment": { "$ref": "levelrules.schema.json#/$defs/comment" },
        "rules": { "$ref": "levelrules.schema.json#/$defs/ruleList" }
      },
      "additionalProperties": false
    }
  }
}
