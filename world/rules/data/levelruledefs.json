  "presets": {
    "plane": {
      "rules": [
        {
          "requires": { "rule": "plane_gun" },
          "when": ["!hard_logic"]
        },
        {
          "requires": {
            "or": [{ "rule": "plane_gun" }, { "rule": "plane_bombs" }]
          },
          "when": ["hard_logic"]
        }
      ]
    },
    "duck_or_dash": {
      "rules": [
        {
          "requires": {
            "or": [{ "rule": "duck" }, { "rule": "dash" }]
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_and_dash": {
      "rules": [
        {
          "requires": {
            "and": [{ "rule": "duck" }, { "rule": "dash" }]
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "parry_or_psugar": {
      "rules": [
        {
          "requires": {
            "or": [{ "rule": "parry" }, { "rule": "psugar" }]
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_or_parry": {
      "rules": [
        {
          "requires": {
            "or": [{ "rule": "dash" }, { "rule": "parry" }]
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_and_parry": {
      "rules": [
        {
          "requires": {
            "and": [{ "rule": "dash" }, { "rule": "parry" }]
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_parry_or_psugar": {
      "rules": [
        {
          "requires": {
            "or": [
              { "rule": "dash" },
              { "rule": "parry" },
              { "rule": "psugar" }
            ]
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_and_parry": {
      "rules": [
        {
          "requires": {
            "and": [{ "rule": "duck" }, { "rule": "parry" }]
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_dash_and_parry": {
      "rules": [
        {
          "requires": {
            "and": [{ "rule": "duck" }, { "rule": "dash" }, { "rule": "parry" }]
          },
          "when": ["rando_abilities"]
        }
      ]
    }
  },

  "levels": {
    "level_boss_veggies": {
      "locations": {
        "loc_level_boss_veggies": {},
        "loc_level_boss_veggies_topgrade": {},
        "loc_level_boss_veggies_secret": {},
        "loc_level_boss_veggies_event_agrade": {},
        "loc_level_boss_veggies_dlc_chaliced": {},
        "loc_level_boss_veggies_event_dlc_chaliced": {}
      }
    },
    "level_boss_slime": {
      "locations": {
        "loc_level_boss_slime": {},
        "loc_level_boss_slime_topgrade": {},
        "loc_level_boss_slime_event_agrade": {},
        "loc_level_boss_slime_dlc_chaliced": {},
        "loc_level_boss_slime_event_dlc_chaliced": {}
      }
    }
  }
}
