{
  "$comment": "Copyright 2025-2026 JKLeckr, SPDX-License-Identifier: MPL-2.0",
  "presets": {
    "plane": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_plane_gun"] } },
          "when": ["!hard_logic"]
        },
        {
          "requires": {
            "rule": {
              "has": ["item_plane_gun", "item_plane_bombs"],
              "has_any": true
            }
          },
          "when": ["hard_logic"]
        }
      ]
    },
    "duck": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_ability_duck"] } },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_ability_dash"] } },
          "when": ["rando_abilities"]
        }
      ]
    },
    "parry": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_ability_parry"] } },
          "when": ["rando_abilities", "!dlc_chalice_only"]
        },
        {
          "requires": {
            "rule": {
              "has": ["item_ability_parry", "item_ability_dash"]
            }
          },
          "when": ["rando_abilities", "dlc_chalice_only"]
        }
      ]
    },
    "psugar": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_charm_psugar"] } },
          "when": ["rando_abilities"]
        }
      ]
    },
    "plane_parry": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_ability_plane_parry"] } },
          "when": ["rando_abilities"]
        }
      ]
    },
    "plane_shrink": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_ability_plane_shrink"] } },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_or_dash": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_duck", "item_ability_dash"],
              "has_any": true
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_and_dash": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_duck", "item_ability_dash"]
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "parry_or_psugar": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_parry", "item_charm_psugar"],
              "has_any": true
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_or_parry": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_dash", "item_ability_parry"],
              "has_any": true
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_and_parry": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_dash", "item_ability_parry"]
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_parry_or_psugar": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": [
                "item_ability_dash",
                "item_ability_parry",
                "item_charm_psugar"
              ],
              "has_any": true
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_and_parry": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_duck", "item_ability_parry"]
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_dash_and_parry": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": [
                "item_ability_duck",
                "item_ability_dash",
                "item_ability_parry"
              ]
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "any_super": {
      "rules": [
        { "requires": { "rule": { "has_group": "Super", "count": 1 } } }
      ]
    },
    "weapon_ex": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has_selection": "all_weapon_ex",
              "has_any": true
            }
          },
          "when": ["weapon_ex_rando"]
        }
      ]
    },
    "topgrade": {
      "requires_presets": ["parry", "any_super", "weapon_ex"],
      "rules": [
        { "requires": { "preset": "parry" } },
        {
          "requires": {
            "or": [{ "preset": "any_super" }, { "preset": "weapon_ex" }]
          },
          "when": ["weapon_ex_rando"]
        }
      ]
    },
    "plane_topgrade": {
      "requires_presets": ["plane_parry"],
      "rules": [
        { "requires": { "preset": "plane_parry" } },
        {
          "requires": {
            "rule": {
              "has": [
                "item_plane_ex",
                "item_plane_super",
                "item_dlc_cplane_ex",
                "item_dlc_cplane_super"
              ],
              "has_any": true
            }
          },
          "when": ["weapon_ex_rando"]
        }
      ]
    },
    "rungun_topgrade": {
      "requires_presets": ["parry", "dash"],
      "rules": [
        { "requires": { "preset": "parry" } },
        {
          "requires": { "preset": "dash" },
          "when": ["dlc_chalice_only"]
        }
      ]
    },
    "dlc_cookie": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_charm_dlc_cookie"] } },
          "when": ["dlc_cookie"]
        }
      ]
    },
    "dlc_doublejump": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_ability_dlc_cdoublejump"] } },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_or_dlc_doublejump": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_ability_dash"] } },
          "when": ["!dlc_chalice"]
        },
        {
          "requires": {
            "rule": {
              "has": ["item_ability_dash", "item_ability_dlc_cdoublejump"]
            }
          },
          "when": ["dlc_chalice"]
        }
      ]
    },
    "dlc_boss_chaliced": {
      "requires_presets": ["dlc_cookie", "topgrade", "dash"],
      "rules": [
        { "requires": { "preset": "dlc_cookie" } },
        {
          "requires": { "preset": "topgrade" },
          "when": ["dlc_chaliced_grade_required"]
        },
        {
          "requires": { "preset": "dash" },
          "when": ["dlc_chaliced_grade_required", "!dlc_chalice_only"]
        }
      ]
    },
    "dlc_boss_plane_chaliced": {
      "requires_presets": ["dlc_cookie", "plane_topgrade"],
      "rules": [
        { "requires": { "preset": "dlc_cookie" } },
        {
          "requires": { "preset": "plane_topgrade" },
          "when": ["dlc_chaliced_grade_required"]
        }
      ]
    },
    "dlc_boss_chaliced_parry": {
      "$comment": "This is the assumption parry is already required in a different rule",
      "requires_presets": ["dlc_boss_chaliced", "dash"],
      "rules": [
        { "requires": { "preset": "dlc_boss_chaliced" } },
        {
          "requires": { "preset": "dash" },
          "when": ["!dlc_chaliced_grade_required"]
        }
      ]
    },
    "dlc_rungun_chaliced": {
      "requires_presets": ["dlc_cookie", "rungun_topgrade", "dash"],
      "rules": [
        { "requires": { "preset": "dlc_cookie" } },
        {
          "requires": { "preset": "rungun_topgrade" },
          "when": ["dlc_rungun_chaliced_grade_required"]
        },
        {
          "requires": { "preset": "dash" },
          "when": ["dlc_rungun_chaliced_grade_required", "!dlc_chalice_only"]
        }
      ]
    },
    "dlc_rungun_chaliced_parry": {
      "$comment": "This is the assumption parry is already required in a different rule",
      "requires_presets": ["dlc_rungun_chaliced", "dash"],
      "rules": [
        { "requires": { "preset": "dlc_rungun_chaliced" } },
        {
          "requires": { "preset": "dash" },
          "when": ["!dlc_chaliced_grade_required"]
        }
      ]
    },
    "dlc_relic": {
      "rules": [
        {
          "requires": {
            "rule": { "has": ["item_charm_dlc_broken_relic"], "count": 1 }
          }
        }
      ]
    }
  }
}
