{
  "$comment": "Copyright 2025-2026 JKLeckr, SPDX-License-Identifier: MPL-2.0",
  "presets": {
    "plane": {
      "rules": [
        {
          "requires": { "rule": { "has": ["item_plane_gun"] } },
          "when": ["!hard_logic"]
        },
        {
          "requires": {
            "rule": {
              "has": ["item_plane_gun", "item_plane_bombs"],
              "has_any": true
            }
          },
          "when": ["hard_logic"]
        }
      ]
    },
    "duck_or_dash": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_duck", "item_ability_dash"],
              "has_any": true
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_and_dash": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_duck", "item_ability_dash"]
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "parry_or_psugar": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_parry", "item_charm_psugar"],
              "has_any": true
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_or_parry": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_dash", "item_ability_parry"],
              "has_any": true
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_and_parry": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_dash", "item_ability_parry"]
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "dash_parry_or_psugar": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": [
                "item_ability_dash",
                "item_ability_parry",
                "item_charm_psugar"
              ],
              "has_any": true
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_and_parry": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": ["item_ability_duck", "item_ability_parry"]
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    },
    "duck_dash_and_parry": {
      "rules": [
        {
          "requires": {
            "rule": {
              "has": [
                "item_ability_dash",
                "item_ability_parry",
                "item_charm_psugar"
              ]
            }
          },
          "when": ["rando_abilities"]
        }
      ]
    }
  }
}
